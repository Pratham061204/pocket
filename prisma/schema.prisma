generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id         String   @id @default(cuid())
  supabaseId String   @unique
  name       String
  email      String   @unique
  avatarUrl  String?
  createdAt  DateTime @default(now())

  memberships         GroupMember[]
  paidExpenses        Expense[]
  splits              ExpenseSplit[]
  sentSettlements     Settlement[]  @relation("Payer")
  receivedSettlements Settlement[]  @relation("Receiver")
  activities          Activity[]
}

model Group {
  id          String   @id @default(cuid())
  name        String
  currency    String   @default("INR")
  inviteCode  String   @unique @default(cuid())
  createdById String
  createdAt   DateTime @default(now())

  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]
  activities  Activity[]
}

model GroupMember {
  id       String   @id @default(cuid())
  userId   String
  groupId  String
  joinedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model Expense {
  id               String    @id @default(cuid())
  groupId          String
  title            String
  totalAmount      Decimal   @db.Decimal(10, 2)
  paidById         String
  splitType        SplitType
  createdAt        DateTime  @default(now())
  deletedAt        DateTime?
  receiptUrl       String?
  isRecurring      Boolean   @default(false)
  recurringDay     Int?
  lastGeneratedAt  DateTime?

  group  Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidBy User           @relation(fields: [paidById], references: [id])
  splits ExpenseSplit[]

  @@index([groupId, deletedAt])
  @@index([groupId, isRecurring])
}

model ExpenseSplit {
  id         String  @id @default(cuid())
  expenseId  String
  userId     String
  amountOwed Decimal @db.Decimal(10, 2)

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([expenseId, userId])
}

model Settlement {
  id         String   @id @default(cuid())
  groupId    String
  payerId    String
  receiverId String
  amount     Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())

  group    Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer    User  @relation("Payer", fields: [payerId], references: [id])
  receiver User  @relation("Receiver", fields: [receiverId], references: [id])
}

model Activity {
  id          String       @id @default(cuid())
  groupId     String
  userId      String
  type        ActivityType
  description String
  metadata    Json?
  createdAt   DateTime     @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@index([groupId, createdAt(sort: Desc)])
}

enum SplitType {
  EQUAL
  UNEQUAL
}

enum ActivityType {
  EXPENSE_ADDED
  EXPENSE_DELETED
  SETTLEMENT_COMPLETED
  MEMBER_JOINED
  MEMBER_LEFT
}
